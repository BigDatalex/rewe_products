{
  "manifest_version": 3,
  "name": "REWE Rezept-Optimierer",
  "version": "1.0.0",
  "description": "Tauscht auf REWE-Mapping-Seiten Produkte auf eigene Matches (günstigste oder Angebote) – mit Panel und Live-Statistik.",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://www.rewe.de/*",
    "https://shop.rewe.de/*",
    "https://bigdatalex.github.io/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rewe-rezept-optimierer@bigdatalex.github.io",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Rezept-Optimierer öffnen",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
